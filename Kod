            <Moon size={40} className="mx-auto mb-4 text-blue-500" />
            <h3 className="text-3xl font-black mb-4">Uyku Arkadaşı</h3>
            <button onClick={simulateVoiceAnalysis} className="w-full py-5 bg-blue-600 text-white rounded-[2rem] text-xl font-black">
              {loading ? 'Hazırlanıyor...' : isRecording ? 'Dinliyorum...' : 'Hadi Masal Anlat! 🌙'}
            </button>
          </div>

          <div className="bg-white p-6 rounded-[2rem] shadow-lg border-2 border-emerald-100">
            <h3 className="text-xl font-bold mb-4">Bugün nasıl hissediyorsun?</h3>
            {!hasCheckedMood ? (
              <div className="flex justify-around">
                {['😊', '😴', '🤔', '🤩'].map(emoji => (
                  <button key={emoji} onClick={() => { addPoints(20); setHasCheckedMood(true); }} className="text-4xl hover:scale-110 transition-transform">{emoji}</button>
                ))}
              </div>
            ) : (
              <p className="text-emerald-600 font-bold text-center">Harika! +20 Puan kazandın! 🌟</p>
            )}
          </div>
        </div>

        {story && <div className="bg-white p-8 rounded-3xl shadow-md prose"><ReactMarkdown>{story}</ReactMarkdown></div>}
      </div>
    </div>
  );
};

