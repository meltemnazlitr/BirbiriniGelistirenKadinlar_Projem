import { GoogleGenAI } from "@google/genai";

const ai = new GoogleGenAI({ apiKey: "YOUR_GEMINI_API_KEY" }); // Lovable'da kendi anahtarını eklemelisin

export const generateStory = async (mood: string, age: number) => {
  const model = "gemini-3-flash-preview";
  const prompt = `Çocuklar için ${age} yaşında bir çocuğa uygun, ${mood} ruh haline göre sakinleştirici veya neşeli bir uyku masalı anlat. Masal kısa ve eğitici olsun.`;
  const response = await ai.models.generateContent({ model, contents: prompt });
  return response.text;
};

export const analyzeMood = async (text: string) => {
  const model = "gemini-3-flash-preview";
  const prompt = `Şu metne göre kullanıcının ruh halini analiz et ve ona olumlu, motive edici bir not kağıdı mesajı yaz: "${text}"`;
  const response = await ai.models.generateContent({ model, contents: prompt });
  return response.text;
};

import React, { useState } from 'react';
import { motion } from 'motion/react';
import { UserInfo } from '../types';

interface OnboardingProps {
  onComplete: (info: UserInfo) => void;
}

export const Onboarding: React.FC<OnboardingProps> = ({ onComplete }) => {
  const [name, setName] = useState('');
  const [age, setAge] = useState<number>(0);
  const [avatar, setAvatar] = useState<'orange' | 'gray'>('orange');

  const handleSubmit = (e: React.FormEvent) => {
    e.preventDefault();
    if (name && age > 0) {
      onComplete({ name, age, avatar, points: 100, unlockedItems: [] });
    }
  };

  return (
    <div className="min-h-screen bg-white flex items-center justify-center p-6 font-sans">
      <motion.div initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }} className="max-w-md w-full space-y-8 text-center">
        <h1 className="text-4xl font-bold text-zinc-900 tracking-tight">Elimde Olan Sağlık</h1>
        <form onSubmit={handleSubmit} className="space-y-6 text-left">
          <input type="text" required value={name} onChange={(e) => setName(e.target.value)} className="w-full px-4 py-3 rounded-xl border border-zinc-200" placeholder="İsmin nedir?" />
          <input type="number" required value={age || ''} onChange={(e) => setAge(parseInt(e.target.value))} className="w-full px-4 py-3 rounded-xl border border-zinc-200" placeholder="Kaç yaşındasın?" />
          <div className="grid grid-cols-2 gap-4">
            <button type="button" onClick={() => setAvatar('orange')} className={`p-4 rounded-3xl border-4 ${avatar === 'orange' ? 'border-emerald-500 bg-emerald-50' : 'border-zinc-100'}`}>
              <span className="text-4xl">🐠</span>
              <p className="text-[10px] font-black uppercase mt-2">Turuncu Balık</p>
            </button>
            <button type="button" onClick={() => setAvatar('gray')} className={`p-4 rounded-3xl border-4 ${avatar === 'gray' ? 'border-emerald-500 bg-emerald-50' : 'border-zinc-100'}`}>
              <span className="text-4xl">🐟</span>
              <p className="text-[10px] font-black uppercase mt-2">Koyu Balık</p>
            </button>
          </div>
          <button type="submit" className="w-full py-4 bg-zinc-900 text-white rounded-xl font-semibold">Hadi Başlayalım!</button>
        </form>
      </motion.div>
    </div>
  );
};

import React, { useState } from 'react';
